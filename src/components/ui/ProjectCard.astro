---
import { Image } from "astro:assets";
import { type CollectionEntry } from "astro:content";

import CirclePlay from "@lucide/astro/icons/circle-play";
import FileText from "@lucide/astro/icons/file-text";
import Github from "@lucide/astro/icons/github";

import Link from "@/components/ui/Link.astro";
import TechBadge from "@/components/ui/TechBadge.astro";

import { TECHS_MAP } from "@/consts/techs";
import { getTechObjects } from "@/lib/techs";

interface Props {
  project: CollectionEntry<"projects">;
}

const { project } = Astro.props;

const techs = project.data.tags.map((id) => TECHS_MAP[id]);
const languages = getTechObjects(project.data.languages);
---

<article
  class:list={[
    "group relative overflow-hidden flex flex-col ",
    "bg-card rounded-2xl border border-border shadow shadow-foreground/20",
    "timeline-view animate-blink animate-range-[entry_10%_contain_25%] ",
  ]}
>
  <header class="aspect-video overflow-hidden relative">
    <Image
      src={project.data.image}
      alt={project.data.title}
      class="h-full w-full object-cover transition-transform duration-250 group-hover:scale-110"
      width={1280}
      height={720}
      loading="lazy"
      quality="max"
    />

    <div
      class="absolute inset-0 bg-linear-to-b from-transparent via-black/35 to-black flex items-end p-4"
    >
      <div class="w-full flex justify-between items-center">
        <h3
          transition:name={`title-${project.id}`}
          class="text-xl font-semibold text-zinc-50"
        >
          {project.data.title}
        </h3>
        <div class="flex gap-3">
          {languages.map((item) => <item.logo class="h-5.5 w-auto" />)}
        </div>
      </div>
    </div>
  </header>

  <main class="p-6 flex flex-col flex-1">
    <div class="flex flex-wrap gap-1.5 mb-5 items-start">
      {
        techs.map((item) => {
          return (
            <TechBadge
              name={item.name}
              light={item.logo}
              dark={item.darkLogo}
            />
          );
        })
      }
    </div>

    <p class="text-muted flex-1">
      {project.data.description}
    </p>
  </main>

  <footer
    class="flex items-center border-t border-border divide-x divide-border"
  >
    {
      project.data.demo && (
        <Link
          href={project.data.demo}
          variant="card"
          class="text-foreground!"
        >
          <CirclePlay size={16} />
          Demo
        </Link>
      )
    }

    <Link
      href={"/proyectos/" + project.id}
      variant="card"
    >
      <FileText size={16} />
      Detalles
    </Link>

    {
      project.data.repository && (
        <Link
          href={project.data.repository}
          variant="card"
        >
          <Github size={16} />
          Repositorio
        </Link>
      )
    }
  </footer>
</article>
