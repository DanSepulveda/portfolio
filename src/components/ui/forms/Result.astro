---
import { MailCheck, MailX } from "@lucide/astro";
import type { HTMLAttributes } from "astro/types";

import { INTERNAL_URLS } from "@/consts/navigation";
import Link from "@/components/ui/Link.astro";

interface Props extends HTMLAttributes<"div"> {
  success?: boolean;
}

const { success = false, ...rest } = Astro.props;

const Icon = success ? MailCheck : MailX;
const title = success ? "¡Mensaje enviado!" : "Oh no...";
const description = success
  ? "Gracias por contactarme. Responderé a la brevedad."
  : "Hubo un problema. Por favor intenta más tarde.";

const variant = success ? "success" : "error";

const variants = {
  success: "bg-green-700/80",
  error: "bg-red-400",
};
---

<div
  class="hidden flex-col h-full"
  {...rest}
>
  <div
    class:list={[
      "py-12 [clip-path:ellipse(80%_100%_at_50%_0%)]",
      variants[variant],
    ]}
  >
    <Icon
      size={110}
      class="mx-auto text-white"
    />
  </div>
  <div class="flex-1 text-center pt-10 space-y-8">
    <h2 class="text-foreground text-4xl">{title}</h2>
    <p class="text-muted max-w-2xs mx-auto text-balance">{description}</p>
    <Link href={INTERNAL_URLS.home}>Volver al inicio</Link>
  </div>
</div>
