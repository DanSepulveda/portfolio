---
import CopyIcon from "@lucide/astro/icons/copy";
import { SITE } from "@/consts/config";

const [user, domain] = SITE.author.email.split("@");
---

<div
  class="group flex justify-between items-center gap-2 px-2 py-1 rounded-lg bg-background/70 w-full border border-border"
>
  <span
    id="email-text"
    class="text-sm font-medium px-2 select-none text-foreground flex"
    aria-hidden="true"
  >
    <span id="user">{user}</span>
    <span id="domain">{domain}</span>
  </span>
  <div class="relative flex flex-col items-center">
    <button
      id="copy-button"
      class="inline-flex items-center justify-center rounded-lg transition-all duration-250 size-9 [&>svg]:size-4.5 [&_svg]:transition-colors [&_svg]:duration-250 [&_svg]:stroke-muted hover:[&_svg]:stroke-foreground hover:bg-foreground/5 dark:hover:bg-foreground/15 cursor-pointer"
      aria-label="Copiar correo electrónico"
      aria-describedby="copy-status"
    >
      <CopyIcon class="size-4" />
    </button>
    <span
      id="copy-status"
      class="sr-only"
      aria-live="polite"
    ></span>
    <span
      id="tooltip"
      class="hidden absolute bottom-10 bg-black/70 px-2 py-1 rounded-md text-white text-sm animate-zoom-in animate-duration-200 select-none"
      aria-hidden={true}
      >Copiado</span
    >
  </div>
</div>
<style>
  #user::after {
    content: "@";
  }
</style>

<script>
  import { $, addClass, removeClass } from "@/lib/dom";

  document.addEventListener("astro:page-load", () => {
    const button = $("#copy-button") as HTMLButtonElement;
    const tooltip = $("#tooltip") as HTMLSpanElement;
    const user = $("#user") as HTMLSpanElement;
    const domain = $("#domain") as HTMLSpanElement;
    const status = $("#copy-status") as HTMLSpanElement;

    button?.addEventListener("click", () => {
      const email = `${user.innerText}@${domain.innerText}`;
      status.textContent = "Correo copiado al portapapeles";

      navigator.clipboard.writeText(email).then(() => {
        removeClass(tooltip, "hidden");

        setTimeout(() => {
          status.textContent = "";
          addClass(tooltip, "hidden");
        }, 2000);
      });
    });
  });
</script>
