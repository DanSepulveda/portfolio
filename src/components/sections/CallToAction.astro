---
import MailIcon from "@lucide/astro/icons/mail";

import CopyEmail from "@/components/ui/CopyEmail.astro";
import Link from "@/components/ui/Link.astro";

import { INTERNAL_URLS } from "@/consts/navigation";
---

<section
  id="contact"
  class="py-24 bg-background"
>
  <div class="page">
    <div
      class="bg-linear-to-br from-cyan-800 via-cyan-700 to-cyan-600 rounded-3xl p-8 md:p-16 shadow-2xl shadow-indigo-500/20"
    >
      <div
        class="z-10 flex flex-col lg:flex-row items-center justify-between gap-12"
      >
        <div class="max-w-lg text-center lg:text-left">
          <h2 class="text-xl md:text-2xl font-bold text-white mb-6">
            ¿Te gusta lo que ves? <br class="hidden md:block" />
            <span class="text-3xl md:text-5xl font-extrabold">Conversemos</span>
          </h2>

          <p
            class="text-primary-foreground text-lg mb-0 font-light text-balance"
          >
            Hablemos sobre cómo mis habilidades pueden ayudar a alcanzar los
            objetivos de tu empresa.
          </p>
        </div>

        <div class="flex flex-col gap-4 lg:gap-8 w-full max-w-3xs lg:w-auto">
          <CopyEmail />

          <Link
            href={INTERNAL_URLS.contact}
            variant="white"
            ><MailIcon />Enviar mensaje</Link
          >
        </div>
      </div>
    </div>
  </div>
</section>
