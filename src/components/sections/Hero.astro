---
import Link from "@/components/ui/Link.astro";
import Status from "@/components/ui/Status.astro";
import Title from "@/components/ui/Title.astro";

import { INTERNAL_URLS } from "@/consts/navigation";
import { getTechObjects } from "@/lib/techs";

const languages = getTechObjects(["javascript", "typescript", "python"]);
---

<section
  class="relative isolate pt-24 pb-20 lg:pt-36 overflow-hidden bg-background"
>
  <div class="absolute top-0 left-1/2 -translate-x-1/2 w-full h-full -z-10">
    <div
      class="absolute top-[30%] left-[10%] w-[25%] h-[25%] rounded-full bg-indigo-500/20 blur-[120px]"
    >
    </div>
    <div
      class="absolute bottom-[25%] right-[-5%] w-[30%] h-[25%] rounded-full bg-blue-500/20 blur-[100px]"
    >
    </div>
  </div>

  <div class="page relative flex flex-col items-center text-center">
    <Status
      badge={true}
      class="mb-6 animate-fade-in-up"
    >
      Disponible para nuevos retos
    </Status>

    <Title
      main="Aplicaciones web"
      accent="modernas y escalables"
    />

    <p class="max-w-xl text-lg mb-10 leading-relaxed text-muted">
      Soy Daniel Sepúlveda, <span class="font-semibold text-foreground"
        >Desarrollador Full Stack</span
      > con más de 3 años de experiencia creando soluciones digitales robustas.
    </p>

    <div
      class="flex flex-col md:flex-row justify-center items-center gap-4 w-full max-w-sm px-10 [&>a]:w-full md:[&>a]:w-auto mb-16"
    >
      <Link
        href="#proyectos"
        variant="outline"
        >Ver proyectos</Link
      >
      <Link href={INTERNAL_URLS.contact}>Hablemos</Link>
    </div>

    <div class="animate-blurred-fade-in animate-duration-600">
      <p
        id="lista-tecnologias"
        class="font-medium tracking-wide text-muted mb-2"
      >
        Lenguajes que utilizo
      </p>
      <ul
        aria-labelledby="lista-tecnologias"
        class="flex flex-wrap justify-center gap-x-10 gap-y-2"
      >
        {
          languages.map((item) => (
            <li class="flex items-center justify-center gap-2 py-2">
              <item.logo
                class="h-6 w-auto"
                aria-hidden="true"
              />
              <span class="font-medium text-foreground">{item.name}</span>
            </li>
          ))
        }
      </ul>
    </div>
  </div>
</section>
