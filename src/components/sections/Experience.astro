---
import Building from "@lucide/astro/icons/building-2";
import ChevronRight from "@lucide/astro/icons/chevron-right";

import type { ExperienceProps } from "@/consts/experience";

interface Props {
  title: string;
  items: ExperienceProps[];
}

const { title, items } = Astro.props;
---

<section class="max-w-3xl mx-auto py-12">
  <h2 class="text-2xl text-foreground mb-8 font-semibold">{title}</h2>

  <ol class="space-y-12">
    {
      items.map((item) => (
        <li class="relative pl-4 border-l-2 border-muted/30 group">
          <div class="absolute -left-2.25 top-1 size-4 bg-white border-2 border-primary rounded-full group-hover:bg-primary transition-colors" />

          <div class="flex flex-col md:flex-row md:justify-between md:items-center">
            <h3 class="text-lg font-medium text-foreground">{item.title}</h3>
            <span class="text-muted flex items-center gap-1.5">
              <Building class="size-4.5" />
              {item.institution}
            </span>
          </div>

          <span class="text-muted text-sm">
            {item.startDate} — {item.endDate}
          </span>

          <ul class="py-4 space-y-4">
            {item.description.map((text) => (
              <li class="text-muted flex items-start gap-1">
                <ChevronRight
                  class="text-primary shrink-0"
                  width={18}
                />
                {text}
              </li>
            ))}
          </ul>

          <ul
            class="flex flex-wrap gap-2"
            aria-label="Tecnologías utilizadas"
          >
            {item.techs.map((tech) => (
              <li class="text-xs font-mono bg-muted/10 text-muted px-2 py-1 rounded">
                {tech}
              </li>
            ))}
          </ul>
        </li>
      ))
    }
  </ol>
</section>
