---
import { LoaderCircle, SendHorizontal } from "@lucide/astro";

import { SOCIALS } from "@/consts/social";
import Layout from "@/layouts/Layout.astro";
import CopyEmail from "@/components/ui/CopyEmail.astro";
import Link from "@/components/ui/Link.astro";
import Title from "@/components/ui/Title.astro";
import Input from "@/components/ui/forms/Input.astro";
import Result from "@/components/ui/forms/Result.astro";
import Textarea from "@/components/ui/forms/Textarea.astro";
import {
  baseButtonStyle,
  primaryButtonStyle,
} from "@/components/ui/base-styles";
---

<Layout
  title="Contacto"
  description="¿Tienes un proyecto en mente o buscas un desarrollador Full Stack para tu equipo? Ponte en contacto conmigo y hablemos de cómo puedo ayudarte."
>
  <section class="py-30 bg-background">
    <div
      class="page grid grid-cols-1 md:grid-cols-2 gap-12 lg:gap-16 items-start"
    >
      <div class="flex flex-col gap-6">
        <Title
          main="Envíame un"
          accent="mensaje"
        />

        <p class="text-lg text-muted leading-relaxed">
          Estoy disponible para colaboraciones y oportunidades. Puedes
          contactarme a través del formulario o directamente por email.
        </p>

        <div class="flex items-center gap-4">
          <div class="w-fit">
            <CopyEmail />
          </div>
          {
            SOCIALS.map((social) => (
              <Link
                href={social.url}
                variant="icon"
                aria-label={social.label}
              >
                <social.image />
              </Link>
            ))
          }
        </div>
      </div>

      <div
        class="bg-card border border-border rounded-2xl h-125 shadow-sm flex flex-col justify-center overflow-hidden"
      >
        <Result
          id="result-success"
          success
        />
        <Result id="result-error" />

        <form
          id="form"
          class="flex flex-col gap-5 mx-6 md:mx-8"
        >
          <Input
            label="Nombre"
            name="name"
            placeholder="Tu nombre"
            autocomplete="name"
          />

          <Input
            label="Correo electrónico"
            name="email"
            placeholder="tu@email.com"
            autocomplete="email"
          />

          <Textarea
            label="Mensaje"
            name="message"
            placeholder="Cuéntame sobre tu proyecto o consulta..."
            rows={4}
          />

          <button
            type="submit"
            class:list={[baseButtonStyle, primaryButtonStyle, "cursor-pointer"]}
          >
            <span id="btn-text">Enviar mensaje</span>
            <SendHorizontal id="btn-icon" />
            <LoaderCircle
              id="btn-loader"
              class="hidden animate-spin"
            />
          </button>
        </form>
      </div>
    </div>
  </section>
</Layout>

<script>
  import { ContactSchema } from "@/lib/schemas";
  import { $, $$, addClass, removeClass, replaceClass } from "@/lib/dom";

  const parseForm = (form: HTMLFormElement) => {
    const formData = new FormData(form);
    const data = Object.fromEntries(formData);
    return ContactSchema.safeParse(data);
  };

  const getControlElements = (name: string) => {
    const input = $(`#${name}`) as HTMLInputElement | HTMLTextAreaElement;
    const wrapper = $(`#${name}-error`) as HTMLDivElement;
    const text = $(`#${name}-error-text`) as HTMLSpanElement;

    return { input, wrapper, text };
  };

  const resetForm = () => {
    const controls = $$(".form-control");

    controls.forEach((control) => {
      const { text, wrapper } = getControlElements(control.id);

      text.textContent = "";
      replaceClass(wrapper, "flex", "hidden");

      replaceClass(control, "border-destructive", "border-border");
      control.setAttribute("aria-invalid", "false");
    });
  };

  const handleResult = (form: HTMLFormElement, success: boolean) => {
    const successContainer = $("#result-success") as HTMLDivElement;
    const errorContainer = $("#result-error") as HTMLDivElement;

    replaceClass(form, "flex", "hidden");
    const container = success ? successContainer : errorContainer;
    replaceClass(container, "hidden", "flex");
  };

  const toggleLoader = (form: HTMLFormElement) => {
    const icon = $("#btn-icon") as HTMLElement;
    const loader = $("#btn-loader") as HTMLElement;
    const text = $("#btn-text") as HTMLSpanElement;

    const loading = !loader.classList.contains("hidden");
    const newText = loading ? "Enviar mensaje" : "Enviando mensaje";
    text.textContent = newText;

    if (loading) {
      addClass(loader, "hidden");
      removeClass(icon, "hidden");
      form.classList.remove("pointer-events-none", "opacity-80");
    } else {
      form.classList.add("pointer-events-none", "opacity-80");
      removeClass(loader, "hidden");
      addClass(icon, "hidden");
    }
  };

  const setupForm = () => {
    const form = $("#form") as HTMLFormElement;

    form?.addEventListener("submit", async (e) => {
      e.preventDefault();
      resetForm();

      const result = parseForm(form);

      if (!result.success) {
        result.error.issues.forEach((issue) => {
          const { wrapper, input, text } = getControlElements(
            String(issue.path[0]),
          );

          text.textContent = issue.message;
          replaceClass(wrapper, "hidden", "flex");

          replaceClass(input, "border-border", "border-destructive");
          input.setAttribute("aria-invalid", "true");
        });

        return;
      }

      try {
        toggleLoader(form);

        const response = await fetch("/api/send-email", {
          method: "POST",
          body: JSON.stringify(result.data),
          headers: { "Content-Type": "application/json" },
        });

        if (response.ok) {
          handleResult(form, true);
        } else {
          throw new Error();
        }
      } catch {
        handleResult(form, false);
      } finally {
        toggleLoader(form);
      }
    });
  };

  document.addEventListener("astro:page-load", setupForm);
</script>
