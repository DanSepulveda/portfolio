---
import { INTERNAL_URLS } from "@/consts/navigation";
import Layout from "@/layouts/Layout.astro";
import Link from "@/components/ui/Link.astro";
---

<Layout
  title="Página no encontrada"
  description="La página que buscas no existe."
  noindex
>
  <section class="py-30 flex-1 flex flex-col justify-center items-stretch">
    <div class="page w-full grid grid-cols-1 md:grid-cols-2 gap-6">
      <div class="flex items-center">
        <iframe
          src="https://giphy.com/embed/LOoaJ2lbqmduxOaZpS"
          width="100%"
          height="202"
          class="giphy-embed"
          allowfullscreen
        ></iframe>
      </div>
      <div class="flex flex-col items-center justify-center text-center gap-8">
        <p
          class="text-7xl md:text-8xl font-bold text-transparent bg-clip-text bg-linear-to-r gradient-brand tracking-tighter"
        >
          404
        </p>

        <div class="flex flex-col gap-3">
          <h1 class="text-3xl md:text-4xl font-extrabold text-foreground">
            Era inevitable...
          </h1>
          <p class="text-lg text-muted leading-relaxed max-w-md">
            La página que buscas no existe.
          </p>
        </div>

        <Link
          href={INTERNAL_URLS.home}
          variant="primary"
        >
          Volver al inicio
        </Link>
      </div>
    </div>
  </section>
</Layout>
